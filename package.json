{
  "name": "@lucasfelipe23/specway",
  "version": "1.5.1",
  "description": "Agent-ready starter kit: spec-driven + TDD methodology with discoverable skills and a consistency checker.",
  "license": "MIT",
  "type": "module",
  "files": [
    "bin/",
    "scripts/check-consistency.mjs",
    "scripts/cut-release.mjs",
    "scripts/session-context.mjs",
    "scripts/update-changelog.mjs",
    "scripts/update-skills-index.mjs",
    "scripts/methodology-guard.mjs",
    "scripts/methodology-nudge.mjs",
    "scripts/merge-hooks.mjs",
    "scripts/spec-tasks.mjs",
    ".claude/settings.json",
    ".claude/skills/",
    ".specs/config.md",
    ".specs/methodology.md",
    ".specs/memory/",
    ".specs/shared/",
    ".specs/templates/",
    "AGENTS.md",
    "CHANGELOG.md",
    "CLAUDE.md",
    "LICENSE",
    "METHODOLOGY.md",
    "README.md"
  ],
  "bin": {
    "specway": "bin/specway.mjs"
  },
  "scripts": {
    "check": "node scripts/check-consistency.mjs",
    "test": "node --test test/*.test.mjs",
    "changelog": "node scripts/update-changelog.mjs",
    "changelog:check": "node scripts/update-changelog.mjs --check",
    "skills:index": "node scripts/update-skills-index.mjs",
    "skills:index:check": "node scripts/update-skills-index.mjs --check",
    "session": "node scripts/session-context.mjs",
    "tasks": "node scripts/spec-tasks.mjs",
    "release": "node scripts/cut-release.mjs",
    "release:check": "node scripts/cut-release.mjs --check"
  }
}
